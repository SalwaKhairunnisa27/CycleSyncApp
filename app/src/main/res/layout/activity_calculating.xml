<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_splash">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="32dp">

        <!-- Spinner loading -->
        <ProgressBar
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:indeterminateTint="#FFFFFF"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Mempersiapkan\nProfil Hormonalmu..."
            android:textSize="18sp"
            android:textColor="#FFFFFF"
            android:fontFamily="serif"
            android:gravity="center"
            android:layout_marginTop="20dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Sedang memproses data siklus &amp; menghitung fasenya"
            android:textSize="11sp"
            android:textColor="#CCFFFFFF"
            android:gravity="center"
            android:layout_marginTop="8dp"/>

        <!-- Check list items -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="28dp">

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="✓ Mengidentifikasi fase aktif saat ini"
                android:textSize="11sp" android:textColor="#CCFFFFFF"
                android:layout_marginBottom="8dp"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="✓ Menghitung jendela masa subur"
                android:textSize="11sp" android:textColor="#CCFFFFFF"
                android:layout_marginBottom="8dp"/>
            <TextView android:id="@+id/tvCheckPersonalisasi"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="⟳ Menyesuaikan rekomendasi personal..."
                android:textSize="11sp" android:textColor="#88FFFFFF"/>
        </LinearLayout>

    </LinearLayout>
</FrameLayout>