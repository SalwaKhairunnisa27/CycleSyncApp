<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:paddingVertical="12dp"
    android:background="?android:attr/selectableItemBackground">

    <!-- Icon circle -->
    <View
        android:id="@+id/viewCircle"
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:background="@drawable/bg_circle_period_medium"
        android:layout_marginEnd="12dp" />

    <!-- Details -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tvHistoryStartDate"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="12 Feb 2026"
            android:textColor="@color/pt"
            android:textSize="13sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvHistoryNotes"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:text="Gejala: Kram | Catatan: Sakit kepala"
            android:textColor="@color/pm"
            android:textSize="10sp"
            android:ellipsize="end"
            android:maxLines="2" />
    </LinearLayout>

    <!-- Cycle Length -->
    <TextView
        android:id="@+id/tvHistoryCycleLength"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="8dp"
        android:background="@drawable/bg_pill_pink"
        android:paddingHorizontal="10dp"
        android:paddingVertical="4dp"
        android:text="28 hari"
        android:textColor="@color/white"
        android:textSize="10sp"
        android:textStyle="bold" />

</LinearLayout>
