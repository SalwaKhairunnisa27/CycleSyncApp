<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_main">

    <!-- Progress bar 50% -->
    <ProgressBar
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="match_parent"
        android:layout_height="4dp"
        android:progress="50"
        android:progressTint="@color/primary"
        android:backgroundTint="#FFE4E9"/>

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="24dp"
        android:paddingTop="32dp"
        android:paddingBottom="16dp">

        <TextView
            android:id="@+id/btnBack"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="←"
            android:textSize="24sp"
            android:textColor="@color/primary_text"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Apa tujuan utamamu?"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="@color/primary_text"
            android:fontFamily="serif"
            android:layout_marginTop="16dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Kami akan menyesuaikan insight &amp; rekomendasi berdasarkan pilihanmu."
            android:textSize="13sp"
            android:textColor="@color/primary_muted"
            android:layout_marginTop="8dp"/>
    </LinearLayout>

    <!-- Body -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="24dp">

            <!-- Goal Card 1: Pelacakan Rutin (selected by default) -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardGoalTrack"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                android:layout_marginBottom="12dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp"
                    android:background="@drawable/bg_card_selected">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <TextView
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:background="@drawable/bg_circle_pink"
                            android:text="🌸"
                            android:gravity="center"
                            android:textSize="18sp"/>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginStart="12dp"
                            android:orientation="vertical">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Pelacakan Rutin"
                                android:textStyle="bold"
                                android:textColor="@color/primary_text"
                                android:textSize="14sp"/>
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Pantau &amp; kelola siklus hormonalmu sehari-hari untuk kesehatan optimal"
                                android:textColor="@color/primary_muted"
                                android:textSize="11sp"/>
                        </LinearLayout>

                        <!-- Check icon -->
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="✓"
                            android:textColor="@color/primary"
                            android:textStyle="bold"/>
                    </LinearLayout>

                    <!-- Feature pills -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginTop="12dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Prediksi Siklus" android:textSize="9sp" android:paddingHorizontal="8dp" android:paddingVertical="4dp"
                            android:background="@drawable/bg_pill_pink" android:textColor="@color/primary" android:layout_marginEnd="6dp"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Log Gejala" android:textSize="9sp" android:paddingHorizontal="8dp" android:paddingVertical="4dp"
                            android:background="@drawable/bg_pill_pink" android:textColor="@color/primary"/>
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Goal Card 2: Promil -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardGoalConceive"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                android:layout_marginBottom="12dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp"
                    android:background="@drawable/bg_card">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <TextView
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:background="@drawable/bg_circle_soft"
                            android:text="🤰"
                            android:gravity="center"
                            android:textSize="18sp"/>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginStart="12dp"
                            android:orientation="vertical">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Persiapan Kehamilan (Promil)"
                                android:textStyle="bold"
                                android:textColor="@color/primary_text"
                                android:textSize="14sp"/>
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Memantau jendela masa subur (ovulasi)"
                                android:textColor="@color/primary_muted"
                                android:textSize="11sp"/>
                        </LinearLayout>
                    </LinearLayout>

                    <!-- Feature pills -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginTop="12dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Kalender Ovulasi" android:textSize="9sp" android:paddingHorizontal="8dp" android:paddingVertical="4dp"
                            android:background="@drawable/bg_pill_soft" android:textColor="@color/primary_muted" android:layout_marginEnd="6dp"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Insight Fertilitas" android:textSize="9sp" android:paddingHorizontal="8dp" android:paddingVertical="4dp"
                            android:background="@drawable/bg_pill_soft" android:textColor="@color/primary_muted"/>
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Hint box -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_pill_soft"
                android:padding="12dp"
                android:layout_marginTop="8dp"
                android:gravity="center_vertical">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="💡" android:textSize="14sp"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Pilihan ini dapat diubah kapan saja di Pengaturan."
                    android:textSize="10sp" android:textColor="@color/primary_muted"
                    android:layout_marginStart="8dp"/>
            </LinearLayout>

        </LinearLayout>
    </ScrollView>

    <!-- Bottom button -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="24dp">
        <Button
            android:id="@+id/btnNext"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="Lanjutkan"
            android:textAllCaps="false"
            android:textStyle="bold"
            android:textColor="@color/white"
            app:backgroundTint="@color/primary"/>
    </LinearLayout>

</LinearLayout>
