<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_main">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#7B5EA7"
        android:orientation="vertical"
        android:paddingHorizontal="24dp"
        android:paddingTop="32dp"
        android:paddingBottom="24dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🎊 Selamat atas Kelahiran Si Kecil!"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="@color/white"
            android:fontFamily="serif" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Waktunya kembali ke pelacakan siklus normalmu"
            android:textSize="12sp"
            android:textColor="#EEFFFFFF"
            android:layout_marginTop="4dp" />
    </LinearLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="20dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                android:layout_marginBottom="16dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp"
                    android:gravity="center"
                    android:background="#7B5EA7"> <!-- Purple grad placeholder -->

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="👶"
                        android:textSize="48sp"
                        android:layout_marginBottom="12dp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Selamat datang di fase baru\nperjalanan kesehatanmu!"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="@color/white"
                        android:fontFamily="serif"
                        android:gravity="center"
                        android:lineSpacingExtra="4dp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Sistem akan mereset mode kehamilan\ndan menyiapkan pelacakan siklus pasca-melahirkan"
                        android:textSize="10sp"
                        android:textColor="#CCFFFFFF"
                        android:layout_marginTop="8dp"
                        android:gravity="center"
                        android:lineSpacingExtra="2dp"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="14dp"
                app:cardElevation="0dp"
                android:layout_marginBottom="16dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="16dp"
                    android:orientation="vertical"
                    android:background="@drawable/bg_card">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="📋 Yang akan direset:"
                        android:textStyle="bold"
                        android:textColor="@color/primary_text"
                        android:textSize="14sp"
                        android:layout_marginBottom="12dp"/>

                    <TextView android:text="↩ Status kehamilan → Tidak aktif" android:textSize="11sp" android:textColor="@color/primary_text" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginBottom="6dp"/>
                    <TextView android:text="↩ Dashboard → Tampilan siklus normal" android:textSize="11sp" android:textColor="@color/primary_text" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginBottom="6dp"/>
                    <TextView android:text="↩ Notifikasi → Reminder siklus standar" android:textSize="11sp" android:textColor="@color/primary_text" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginBottom="6dp"/>
                    <TextView android:text="✓ Riwayat kehamilan → Tersimpan di Room DB" android:textSize="11sp" android:textColor="@color/primary_text" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="14dp"
                app:cardElevation="0dp"
                android:layout_marginBottom="16dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="16dp"
                    android:orientation="vertical"
                    android:background="#FFF3E0"> <!-- Gold light bg -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="⏰ Kapan Haid Kembali?"
                        android:textStyle="bold"
                        android:textColor="#E65100"
                        android:textSize="14sp"
                        android:layout_marginBottom="8dp"/>
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Setelah melahirkan, haid biasanya kembali dalam 6–8 minggu (jika tidak menyusui) atau 6 bulan+ (jika menyusui eksklusif). Masukkan tanggal haid pertama saat sudah kembali."
                        android:textSize="10sp"
                        android:textColor="#5D4037"
                        android:lineSpacingExtra="3dp"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">
        <Button
            android:id="@+id/btnEndPregnancy"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="Kembali ke Pelacakan Siklus →"
            android:textAllCaps="false"
            android:textStyle="bold"
            android:textColor="@color/white"
            app:backgroundTint="@color/primary"/>
        <Button
            android:id="@+id/btnCancel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="← Kembali ke Mode Kehamilan"
            android:textAllCaps="false"
            android:textColor="@color/primary_muted"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_marginTop="8dp"/>
    </LinearLayout>

</LinearLayout>