<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg"
    android:scrollbarThumbHorizontal="@null"
    android:scrollbarThumbVertical="@null">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/primary"
            android:orientation="vertical"
            android:paddingHorizontal="24dp"
            android:paddingTop="32dp"
            android:paddingBottom="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="⚙️ LANGKAH 4 DARI 4"
                android:textSize="9sp"
                android:textStyle="bold"
                android:textColor="@color/primary"
                android:background="@drawable/bg_pill_pink"
                android:paddingHorizontal="8dp"
                android:paddingVertical="4dp"
                android:letterSpacing="0.05"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Atur Pengingat &amp; Preferensi"
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="@color/white"
                android:fontFamily="serif"
                android:layout_marginTop="12dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Langkah terakhir untuk mengoptimalkan pelacakanmu 🌸"
                android:textSize="12sp"
                android:textColor="#EEFFFFFF"
                android:layout_marginTop="4dp" />
        </LinearLayout>

        <!-- Body -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="NOTIFIKASI AKTIF"
                android:textSize="10sp"
                android:textStyle="bold"
                android:textColor="@color/primary_muted"
                android:letterSpacing="0.05"
                android:layout_marginBottom="8dp" />

            <!-- Daily Log Toggle Card -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                app:cardCornerRadius="14dp"
                app:cardElevation="2dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="14dp">
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="🌙 Log Harian"
                            android:textStyle="bold"
                            android:textColor="@color/primary_text"
                            android:textSize="13sp"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Setiap pukul 21.00 — catat mood &amp; gejala"
                            android:textColor="@color/primary_muted"
                            android:textSize="10sp"
                            android:layout_marginTop="2dp"/>
                    </LinearLayout>
                    <androidx.appcompat.widget.SwitchCompat
                        android:id="@+id/switchDailyLog"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:checked="true"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Period Reminder Toggle Card -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                app:cardCornerRadius="14dp"
                app:cardElevation="2dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="14dp">
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="📅 Pengingat Haid"
                            android:textStyle="bold"
                            android:textColor="@color/primary_text"
                            android:textSize="13sp"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="H-3 sebelum tanggal prediksi haid"
                            android:textColor="@color/primary_muted"
                            android:textSize="10sp"
                            android:layout_marginTop="2dp"/>
                    </LinearLayout>
                    <androidx.appcompat.widget.SwitchCompat
                        android:id="@+id/switchPeriod"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:checked="true"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Fertile Toggle Card -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                app:cardCornerRadius="14dp"
                app:cardElevation="2dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="14dp">
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="🌸 Masa Subur"
                            android:textStyle="bold"
                            android:textColor="@color/primary_text"
                            android:textSize="13sp"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="H-2 &amp; hari puncak ovulasi"
                            android:textColor="@color/primary_muted"
                            android:textSize="10sp"
                            android:layout_marginTop="2dp"/>
                    </LinearLayout>
                    <androidx.appcompat.widget.SwitchCompat
                        android:id="@+id/switchFertile"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:checked="true"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Supplement Toggle Card -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="14dp"
                app:cardElevation="2dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="14dp">
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="💊 Pengingat Suplemen"
                            android:textStyle="bold"
                            android:textColor="@color/primary_text"
                            android:textSize="13sp"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Pagi hari sesuai dengan fase aktif"
                            android:textColor="@color/primary_muted"
                            android:textSize="10sp"
                            android:layout_marginTop="2dp"/>
                    </LinearLayout>
                    <androidx.appcompat.widget.SwitchCompat
                        android:id="@+id/switchSupplement"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:checked="false"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="PARTNER SYNC (OPSIONAL)"
                android:textSize="10sp"
                android:textStyle="bold"
                android:textColor="@color/primary_muted"
                android:letterSpacing="0.05"
                android:layout_marginBottom="8dp" />

            <!-- Partner Sync Setup Card -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                app:cardCornerRadius="14dp"
                app:cardElevation="2dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="14dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="12dp">
                        <TextView
                            android:layout_width="36dp"
                            android:layout_height="36dp"
                            android:background="@drawable/bg_pill_pink"
                            android:gravity="center"
                            android:text="💞"
                            android:textSize="16sp"/>
                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:layout_marginStart="10dp">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Hubungkan Pasangan"
                                android:textStyle="bold"
                                android:textColor="@color/primary_text"
                                android:textSize="12sp"/>
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Masukkan nama &amp; no. WhatsApp pasangan"
                                android:textColor="@color/primary_muted"
                                android:textSize="10sp"/>
                        </LinearLayout>
                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Nama Pasangan"
                        android:textSize="9sp"
                        android:textStyle="bold"
                        android:textColor="@color/primary_muted"
                        android:layout_marginBottom="4dp"/>
                    <EditText
                        android:id="@+id/etSetupPartnerName"
                        android:layout_width="match_parent"
                        android:layout_height="44dp"
                        android:hint="cth: Rizky Sayang 💕"
                        android:background="@drawable/bg_card"
                        android:paddingHorizontal="12dp"
                        android:textSize="13sp"
                        android:layout_marginBottom="12dp"
                        android:inputType="textPersonName"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="No. WhatsApp"
                        android:textSize="9sp"
                        android:textStyle="bold"
                        android:textColor="@color/primary_muted"
                        android:layout_marginBottom="4dp"/>
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="12dp">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="44dp"
                            android:background="@drawable/bg_card"
                            android:gravity="center"
                            android:paddingHorizontal="12dp"
                            android:text="🇮🇩 +62"
                            android:textStyle="bold"
                            android:textColor="@color/primary_muted"
                            android:textSize="13sp"
                            android:layout_marginEnd="6dp"/>
                        <EditText
                            android:id="@+id/etSetupPartnerPhone"
                            android:layout_width="0dp"
                            android:layout_height="44dp"
                            android:layout_weight="1"
                            android:hint="812-3456-7890"
                            android:background="@drawable/bg_card"
                            android:paddingHorizontal="12dp"
                            android:textSize="13sp"
                            android:inputType="phone"/>
                    </LinearLayout>

                    <!-- Preview box -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="PREVIEW PESAN"
                        android:textSize="9sp"
                        android:textStyle="bold"
                        android:textColor="@color/primary_muted"
                        android:layout_marginBottom="4dp"/>
                    <TextView
                        android:id="@+id/tvSetupPreviewMessage"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="#DCF8C6"
                        android:textColor="#1A1A1A"
                        android:padding="10dp"
                        android:textSize="11sp"
                        android:lineSpacingExtra="3dp"
                        android:layout_marginBottom="12dp"
                        android:text="CycleSync Update dari Aisyah 🌸\n\nHai sayang, FYI aku lagi di fase Luteal nih.\nMoodku lagi Tenang 😌, energi Sedang.\n\n_Pesan otomatis dari CycleSync_"/>

                    <Button
                        android:id="@+id/btnSetupSavePartner"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="💾 Simpan Kontak Pasangan"
                        android:textSize="12sp"
                        android:backgroundTint="@color/primary"
                        android:textColor="@color/white"
                        android:textAllCaps="false"/>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Bottom Start Button -->
            <Button
                android:id="@+id/btnStartJourney"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="Selesai — Lihat Dashboard 🎉"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="@color/white"
                app:backgroundTint="@color/primary"
                android:textAllCaps="false"/>
        </LinearLayout>
    </LinearLayout>
</ScrollView>