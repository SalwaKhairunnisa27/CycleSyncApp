<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_main">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@color/primary"
            android:padding="20dp">

            <TextView
                android:id="@+id/btnBack"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="← Kembali"
                android:textColor="#CCffffff"
                android:textSize="13sp"
                android:paddingBottom="8dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Partner Sync 💞"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="@android:color/white"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Beritahu pasangan tentang kondisimu hari ini"
                android:textSize="11sp"
                android:textColor="#CCffffff"
                android:layout_marginTop="4dp"/>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Status Fase Card -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp"
                xmlns:app="http://schemas.android.com/apk/res-auto">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="14dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🌸 Status Fase Saat Ini"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:textColor="@color/primary_text"
                        android:layout_marginBottom="8dp"/>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <TextView
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            android:text="🌸"
                            android:textSize="24sp"
                            android:gravity="center"
                            android:background="@color/bg_pink_light"
                            android:layout_marginEnd="12dp"/>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Fase Aktif · Pantau Siklus"
                                android:textSize="13sp"
                                android:textStyle="bold"
                                android:textColor="@color/primary"/>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Mood &amp; kondisi terkini akan dibagikan ke pasangan"
                                android:textSize="10sp"
                                android:textColor="@color/primary_muted"
                                android:layout_marginTop="2dp"/>
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- KONTAK PASANGAN: State Belum Ada -->
            <LinearLayout
                android:id="@+id/layoutNoContact"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginBottom="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="📱 Kontak Pasangan"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:textColor="@color/primary_text"
                    android:layout_marginBottom="8dp"/>

                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="2dp"
                    xmlns:app="http://schemas.android.com/apk/res-auto">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="14dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:background="@color/bg_pink_light"
                            android:padding="12dp"
                            android:gravity="center"
                            android:layout_marginBottom="12dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="💕"
                                android:textSize="24sp"/>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Belum ada kontak tersimpan.\nTambahkan pasanganmu dulu!"
                                android:textSize="10sp"
                                android:textColor="@color/primary_muted"
                                android:gravity="center"
                                android:layout_marginTop="4dp"/>
                        </LinearLayout>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="NAMA PASANGAN"
                            android:textSize="9sp"
                            android:textStyle="bold"
                            android:textColor="@color/primary_muted"
                            android:layout_marginBottom="4dp"/>

                        <EditText
                            android:id="@+id/etPartnerName"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="cth: Rizky Sayang 💕"
                            android:inputType="textPersonName"
                            android:background="@color/bg_pink_light"
                            android:padding="10dp"
                            android:textSize="12sp"
                            android:layout_marginBottom="10dp"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="NO. WHATSAPP"
                            android:textSize="9sp"
                            android:textStyle="bold"
                            android:textColor="@color/primary_muted"
                            android:layout_marginBottom="4dp"/>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:layout_marginBottom="12dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="🇮🇩 +62"
                                android:textSize="11sp"
                                android:textStyle="bold"
                                android:textColor="@color/primary_muted"
                                android:background="@color/bg_pink_light"
                                android:padding="10dp"
                                android:layout_marginEnd="6dp"/>

                            <EditText
                                android:id="@+id/etPartnerPhone"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:hint="812-3456-7890"
                                android:inputType="phone"
                                android:background="@color/bg_pink_light"
                                android:padding="10dp"
                                android:textSize="12sp"/>
                        </LinearLayout>

                        <Button
                            android:id="@+id/btnSaveContact"
                            android:layout_width="match_parent"
                            android:layout_height="48dp"
                            android:text="💾 Simpan Kontak Pasangan"
                            android:textColor="@android:color/white"
                            android:backgroundTint="@color/primary"
                            android:textStyle="bold"/>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>
            </LinearLayout>

            <!-- KONTAK PASANGAN: State Sudah Ada -->
            <LinearLayout
                android:id="@+id/layoutHasContact"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone"
                android:layout_marginBottom="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="📱 Kontak Pasangan"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:textColor="@color/primary_text"
                    android:layout_marginBottom="8dp"/>

                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="2dp"
                    xmlns:app="http://schemas.android.com/apk/res-auto">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:padding="14dp"
                        android:gravity="center_vertical">

                        <TextView
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:text="💞"
                            android:textSize="20sp"
                            android:gravity="center"
                            android:background="@color/primary"
                            android:layout_marginEnd="10dp"/>

                        <TextView
                            android:id="@+id/tvSavedContact"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="—"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            android:textColor="@color/primary_text"/>

                        <TextView
                            android:id="@+id/btnEditContact"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Ubah"
                            android:textSize="10sp"
                            android:textColor="@color/primary"
                            android:textStyle="bold"
                            android:padding="6dp"/>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>
            </LinearLayout>

            <!-- Preview Pesan WhatsApp -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="💬 Preview Pesan WhatsApp"
                android:textSize="12sp"
                android:textStyle="bold"
                android:textColor="@color/primary_text"
                android:layout_marginBottom="8dp"/>

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp"
                xmlns:app="http://schemas.android.com/apk/res-auto">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="14dp">

                    <!-- WhatsApp bubble style -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="#DCF8C6"
                        android:padding="12dp">

                        <TextView
                            android:id="@+id/tvPreviewMessage"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Loading..."
                            android:textSize="11sp"
                            android:textColor="#1a1a1a"
                            android:lineSpacingMultiplier="1.4"/>
                    </LinearLayout>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="🔍 Hanya fase &amp; kondisi umum yang dibagikan. Data medis tetap privat."
                        android:textSize="9sp"
                        android:textColor="@color/primary_muted"
                        android:background="@color/bg_pink_light"
                        android:padding="8dp"
                        android:layout_marginTop="8dp"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Action Buttons -->
            <Button
                android:id="@+id/btnSendWhatsApp"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:text="Beritahu Pasangan via WhatsApp"
                android:textColor="@android:color/white"
                android:backgroundTint="#25D366"
                android:textStyle="bold"
                android:layout_marginBottom="8dp"/>

            <Button
                android:id="@+id/btnShareOther"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:text="Bagikan via Aplikasi Lain"
                android:textColor="@color/primary"
                android:backgroundTint="@android:color/white"
                android:textStyle="bold"
                android:layout_marginBottom="16dp"/>

        </LinearLayout>
    </LinearLayout>
</ScrollView>
