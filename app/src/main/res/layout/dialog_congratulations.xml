<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="24dp"
    android:gravity="center"
    android:background="@drawable/bg_dialog_pregnancy">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="👶🎉🎊"
        android:textSize="54sp"
        android:layout_marginBottom="16dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Selamat atas Kelahiran Si Kecil!"
        android:textSize="20sp"
        android:textStyle="bold"
        android:textColor="@color/pt"
        android:gravity="center"
        android:layout_marginBottom="12dp"
        android:fontFamily="serif"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Selamat datang di fase baru kehidupan Anda! Semoga Ibu dan bayi sehat selalu, serta dipenuhi kebahagiaan setiap harinya."
        android:textSize="13sp"
        android:textColor="@color/pm"
        android:gravity="center"
        android:layout_marginBottom="24dp"
        android:lineSpacingExtra="4dp"/>

    <Button
        android:id="@+id/btnDismissCongrats"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:text="Terima Kasih"
        android:textColor="@color/white"
        android:backgroundTint="@color/purple"
        android:textAllCaps="false"
        android:textStyle="bold"/>

</LinearLayout>
