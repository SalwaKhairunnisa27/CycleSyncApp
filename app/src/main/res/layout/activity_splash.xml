<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_gradient_pink">

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:gravity="center"
        android:orientation="vertical">

        <!-- Logo -->
        <FrameLayout
            android:layout_width="88dp"
            android:layout_height="88dp"
            android:background="@drawable/bg_stat_item"
            android:layout_marginBottom="16dp">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:text="🌸"
                android:textSize="40sp" />
        </FrameLayout>

        <!-- App name -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="CycleSync"
            android:textColor="@color/white"
            android:textSize="34sp"
            android:textStyle="bold"
            android:fontFamily="serif"
            android:letterSpacing="0.02"/>

        <!-- Tagline -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Women's Cycle Tracker"
            android:textColor="#D9FFFFFF"
            android:textSize="12sp" />

        <!-- Divider -->
        <View
            android:layout_width="48dp"
            android:layout_height="2.5dp"
            android:layout_marginTop="22dp"
            android:layout_marginBottom="22dp"
            android:background="#66FFFFFF" />

        <!-- Tombol Mulai -->
        <Button
            android:id="@+id/btnGetStarted"
            android:layout_width="220dp"
            android:layout_height="54dp"
            android:backgroundTint="@color/white"
            android:text="Mulai Sekarang"
            android:textAllCaps="false"
            android:textColor="@color/p"
            android:textSize="14sp"
            android:textStyle="bold"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            app:cornerRadius="30dp"
            xmlns:app="http://schemas.android.com/apk/res-auto"/>

        <!-- Link login -->
        <TextView
            android:id="@+id/tvLoginLink"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:text="Sudah punya akun? Masuk"
            android:textColor="#D1FFFFFF"
            android:textSize="11sp" />

    </LinearLayout>

</FrameLayout>
