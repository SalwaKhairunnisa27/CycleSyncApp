<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg">

    <!-- Header pink -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_gradient_pink"
        android:orientation="vertical"
        android:gravity="center"
        android:paddingTop="60dp"
        android:paddingBottom="40dp"
        android:paddingHorizontal="24dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Selamat Datang"
            android:textSize="26sp"
            android:textStyle="bold"
            android:textColor="@color/white"
            android:fontFamily="serif"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Masuk untuk melanjutkan perjalananmu"
            android:textSize="13sp"
            android:textColor="#EEFFFFFF"
            android:layout_marginTop="4dp"/>
    </LinearLayout>

    <!-- Body -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <!-- Input Email -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ALAMAT EMAIL"
                android:textSize="10sp"
                android:textStyle="bold"
                android:textColor="@color/pm"
                android:letterSpacing="0.05"/>

            <EditText
                android:id="@+id/etEmail"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:background="@drawable/bg_card_outline"
                android:hint="aisyah@email.com"
                android:paddingHorizontal="16dp"
                android:textSize="14sp"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="20dp"
                android:inputType="textEmailAddress"/>

            <!-- Input Password -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="KATA SANDI"
                android:textSize="10sp"
                android:textStyle="bold"
                android:textColor="@color/pm"
                android:letterSpacing="0.05"/>

            <EditText
                android:id="@+id/etPassword"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:background="@drawable/bg_card_outline"
                android:hint="••••••••"
                android:paddingHorizontal="16dp"
                android:textSize="14sp"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="10dp"
                android:inputType="textPassword"/>

            <TextView
                android:id="@+id/tvForgotPassword"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Lupa kata sandi?"
                android:textSize="12sp"
                android:textColor="@color/p"
                android:layout_gravity="end"
                android:layout_marginBottom="30dp"/>

            <!-- Tombol Masuk -->
            <Button
                android:id="@+id/btnLogin"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="Masuk"
                android:textAllCaps="false"
                android:textStyle="bold"
                android:textColor="@color/white"
                app:backgroundTint="@color/p"/>

            <TextView
                android:id="@+id/tvSignUpLink"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Belum punya akun? Daftar Sekarang"
                android:textSize="12sp"
                android:textColor="@color/pm"
                android:layout_gravity="center"
                android:layout_marginTop="24dp"/>

        </LinearLayout>
    </ScrollView>
</LinearLayout>
