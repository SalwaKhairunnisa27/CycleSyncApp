<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_main">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_splash"
            android:orientation="vertical"
            android:paddingHorizontal="24dp"
            android:paddingTop="32dp"
            android:paddingBottom="24dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Log Harian"
                android:textSize="24sp"
                android:textStyle="bold"
                android:textColor="@color/white"
                android:fontFamily="serif" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Senin, 16 Mar 2026 · Hari ke-18"
                android:textSize="13sp"
                android:textColor="#EEFFFFFF"
                android:layout_marginTop="4dp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- Mood Section -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Bagaimana mood kamu?"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="@color/primary_text"
                android:layout_marginBottom="16dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:layout_marginBottom="24dp">

                <!-- Mood Item -->
                <LinearLayout android:id="@+id/moodBahagia" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                    <FrameLayout android:id="@+id/bgMoodBahagia" android:layout_width="56dp" android:layout_height="56dp" android:background="@drawable/bg_mood_unselected">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="😄" android:textSize="28sp" android:layout_gravity="center"/>
                    </FrameLayout>
                    <TextView android:id="@+id/txtMoodBahagia" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Bahagia" android:textSize="10sp" android:textColor="@color/primary_muted" android:layout_marginTop="8dp"/>
                </LinearLayout>

                <LinearLayout android:id="@+id/moodTenang" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                    <FrameLayout android:id="@+id/bgMoodTenang" android:layout_width="56dp" android:layout_height="56dp" android:background="@drawable/bg_mood_unselected">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="😌" android:textSize="28sp" android:layout_gravity="center"/>
                    </FrameLayout>
                    <TextView android:id="@+id/txtMoodTenang" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Tenang" android:textSize="10sp" android:textColor="@color/primary_muted" android:layout_marginTop="8dp"/>
                </LinearLayout>

                <LinearLayout android:id="@+id/moodSedih" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                    <FrameLayout android:id="@+id/bgMoodSedih" android:layout_width="56dp" android:layout_height="56dp" android:background="@drawable/bg_mood_unselected">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="😔" android:textSize="28sp" android:layout_gravity="center"/>
                    </FrameLayout>
                    <TextView android:id="@+id/txtMoodSedih" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Sedih" android:textSize="10sp" android:textColor="@color/primary_muted" android:layout_marginTop="8dp"/>
                </LinearLayout>

                <LinearLayout android:id="@+id/moodEmosi" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                    <FrameLayout android:id="@+id/bgMoodEmosi" android:layout_width="56dp" android:layout_height="56dp" android:background="@drawable/bg_mood_unselected">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="😤" android:textSize="28sp" android:layout_gravity="center"/>
                    </FrameLayout>
                    <TextView android:id="@+id/txtMoodEmosi" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Emosi" android:textSize="10sp" android:textColor="@color/primary_muted" android:layout_marginTop="8dp"/>
                </LinearLayout>

                <LinearLayout android:id="@+id/moodLelah" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                    <FrameLayout android:id="@+id/bgMoodLelah" android:layout_width="56dp" android:layout_height="56dp" android:background="@drawable/bg_mood_unselected">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="😴" android:textSize="28sp" android:layout_gravity="center"/>
                    </FrameLayout>
                    <TextView android:id="@+id/txtMoodLelah" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Lelah" android:textSize="10sp" android:textColor="@color/primary_muted" android:layout_marginTop="8dp"/>
                </LinearLayout>
            </LinearLayout>

            <!-- Energy Level Section -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent" android:layout_height="wrap_content"
                app:cardCornerRadius="16dp" app:cardElevation="0dp" android:layout_marginBottom="16dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="16dp" android:background="@drawable/bg_card">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="12dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="⚡ Level Energi" android:textStyle="bold" android:textColor="@color/primary_text" android:textSize="14sp"/>
                    </LinearLayout>
                    <LinearLayout android:id="@+id/energyLevelGroup" android:layout_width="match_parent" android:layout_height="12dp" android:orientation="horizontal">
                        <View android:id="@+id/energy1" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:background="#F5C9D3" android:layout_marginEnd="6dp"/>
                        <View android:id="@+id/energy2" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:background="#F5C9D3" android:layout_marginEnd="6dp"/>
                        <View android:id="@+id/energy3" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:background="#F5C9D3" android:layout_marginEnd="6dp"/>
                        <View android:id="@+id/energy4" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:background="#F5C9D3" android:layout_marginEnd="6dp"/>
                        <View android:id="@+id/energy5" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:background="#F5C9D3"/>
                    </LinearLayout>
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginTop="8dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Rendah" android:textSize="10sp" android:textColor="@color/primary_muted"/>
                        <TextView android:id="@+id/tvEnergyScore" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="0 / 5" android:gravity="center" android:textSize="11sp" android:textColor="@color/primary_muted" android:textStyle="bold"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Tinggi" android:textSize="10sp" android:textColor="@color/primary_muted"/>
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Gejala Fisik Section -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent" android:layout_height="wrap_content"
                app:cardCornerRadius="16dp" app:cardElevation="0dp" android:layout_marginBottom="16dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="16dp" android:background="@drawable/bg_card">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="🤒 Gejala Fisik" android:textStyle="bold" android:textColor="@color/primary_text" android:textSize="14sp" android:layout_marginBottom="16dp"/>
                    <com.google.android.material.chip.ChipGroup
                        android:id="@+id/chipGroupGejala"
                        android:layout_width="match_parent" android:layout_height="wrap_content"
                        app:chipSpacingHorizontal="8dp" app:chipSpacingVertical="8dp">
                        <com.google.android.material.chip.Chip style="@style/Widget.MaterialComponents.Chip.Action" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Kram Ringan" android:textColor="@color/primary_muted" app:chipStrokeWidth="1dp" app:chipStrokeColor="@color/primary_soft" app:chipCornerRadius="14dp" android:backgroundTint="@color/white"/>
                        <com.google.android.material.chip.Chip style="@style/Widget.MaterialComponents.Chip.Action" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Kembung" android:textColor="@color/primary_muted" app:chipStrokeWidth="1dp" app:chipStrokeColor="@color/primary_soft" app:chipCornerRadius="14dp" android:backgroundTint="@color/white"/>
                        <com.google.android.material.chip.Chip style="@style/Widget.MaterialComponents.Chip.Action" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Sakit Kepala" android:textColor="@color/primary_muted" app:chipStrokeWidth="1dp" app:chipStrokeColor="@color/primary_soft" app:chipCornerRadius="14dp" android:backgroundTint="@color/white"/>
                        <com.google.android.material.chip.Chip style="@style/Widget.MaterialComponents.Chip.Action" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Mual" android:textColor="@color/primary_muted" app:chipStrokeWidth="1dp" app:chipStrokeColor="@color/primary_soft" app:chipCornerRadius="14dp" android:backgroundTint="@color/white"/>
                        <com.google.android.material.chip.Chip style="@style/Widget.MaterialComponents.Chip.Action" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Nyeri Payudara" android:textColor="@color/primary_muted" app:chipStrokeWidth="1dp" app:chipStrokeColor="@color/primary_soft" app:chipCornerRadius="14dp" android:backgroundTint="@color/white"/>
                        <com.google.android.material.chip.Chip style="@style/Widget.MaterialComponents.Chip.Action" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Jerawat" android:textColor="@color/primary_muted" app:chipStrokeWidth="1dp" app:chipStrokeColor="@color/primary_soft" app:chipCornerRadius="14dp" android:backgroundTint="@color/white"/>
                        <com.google.android.material.chip.Chip style="@style/Widget.MaterialComponents.Chip.Action" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Sembelit" android:textColor="@color/primary_muted" app:chipStrokeWidth="1dp" app:chipStrokeColor="@color/primary_soft" app:chipCornerRadius="14dp" android:backgroundTint="@color/white"/>
                        <com.google.android.material.chip.Chip style="@style/Widget.MaterialComponents.Chip.Action" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Insomnia" android:textColor="@color/primary_muted" app:chipStrokeWidth="1dp" app:chipStrokeColor="@color/primary_soft" app:chipCornerRadius="14dp" android:backgroundTint="@color/white"/>
                    </com.google.android.material.chip.ChipGroup>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Status Haid Section -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent" android:layout_height="wrap_content"
                app:cardCornerRadius="16dp" app:cardElevation="0dp" android:layout_marginBottom="16dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="16dp" android:background="@drawable/bg_card">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="🩸 Status Haid Hari Ini" android:textStyle="bold" android:textColor="@color/primary_text" android:textSize="14sp" android:layout_marginBottom="16dp"/>
                    <LinearLayout android:id="@+id/statusHaidGroup" android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal">
                        <TextView android:id="@+id/statusTidak" android:layout_width="0dp" android:layout_height="40dp" android:layout_weight="1" android:text="Tidak" android:gravity="center" android:background="@drawable/bg_card" android:textColor="@color/primary_muted" android:textSize="12sp" android:layout_marginEnd="8dp"/>
                        <TextView android:id="@+id/statusRingan" android:layout_width="0dp" android:layout_height="40dp" android:layout_weight="1" android:text="Ringan" android:gravity="center" android:background="@drawable/bg_card" android:textColor="@color/primary_muted" android:textSize="12sp" android:layout_marginEnd="8dp"/>
                        <TextView android:id="@+id/statusSedang" android:layout_width="0dp" android:layout_height="40dp" android:layout_weight="1" android:text="Sedang" android:gravity="center" android:background="@drawable/bg_card" android:textColor="@color/primary_muted" android:textSize="12sp" android:layout_marginEnd="8dp"/>
                        <TextView android:id="@+id/statusDeras" android:layout_width="0dp" android:layout_height="40dp" android:layout_weight="1" android:text="Deras" android:gravity="center" android:background="@drawable/bg_card" android:textColor="@color/primary_muted" android:textSize="12sp"/>
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Haid Telat Section -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent" android:layout_height="wrap_content"
                app:cardCornerRadius="16dp" app:cardElevation="0dp" android:layout_marginBottom="24dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:padding="16dp" android:background="#FCEEF2" android:gravity="center_vertical">
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="⚠️ Haid Telat >14 Hari?" android:textStyle="bold" android:textColor="@color/primary_text" android:textSize="13sp"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Aktifkan jika haid telat signifikan" android:textSize="10sp" android:textColor="@color/primary_muted" android:layout_marginTop="2dp"/>
                    </LinearLayout>
                    <androidx.appcompat.widget.SwitchCompat android:layout_width="wrap_content" android:layout_height="wrap_content" android:thumbTint="@color/white" app:trackTint="@color/primary_soft" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Save Button -->
            <Button
                android:id="@+id/btnSaveLog"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="💾 Simpan Log Hari Ini"
                android:textAllCaps="false"
                android:textStyle="bold"
                android:textColor="@color/white"
                app:backgroundTint="@color/primary"
                android:layout_marginBottom="20dp"/>

        </LinearLayout>
    </LinearLayout>
</androidx.core.widget.NestedScrollView>
